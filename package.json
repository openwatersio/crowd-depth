{
  "name": "crowd-depth-dev",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest",
    "build": "tsc -b",
    "format": "oxlint --fix && prettier --write .",
    "check": "oxlint && prettier --check . && npm run lint --workspaces --if-present",
    "prepare": "husky",
    "start": "npm run start -w crowd-depth-api"
  },
  "devDependencies": {
    "@types/debug": "^4.1.12",
    "@types/node": "^26.1.0",
    "ajv": "^8.17.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "nock": "^14.0.10",
    "oxlint": "^1.74.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "typescript": "^7.0.2",
    "vitest": "^4.0.8"
  },
  "lint-staged": {
    "**/*": [
      "prettier --write --ignore-unknown",
      "oxlint --fix --no-error-on-unmatched-pattern"
    ]
  },
  "workspaces": {
    "packages": [
      "packages/*"
    ]
  }
}
